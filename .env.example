# Gmail official OAuth client (Desktop-app type) + a refresh token.
# Get these from Google Cloud Console -> APIs & Services -> Credentials.
# Mint the refresh token once with:  uv run python gmail_auth.py
# Scope used: https://www.googleapis.com/auth/gmail.modify  (read/label/trash/draft; cannot permanently delete)
GMAIL_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=xxxxxxxx
GMAIL_REFRESH_TOKEN=1//xxxxxxxx

# Outlook defaults to Safari on macOS and Edge on Windows.
OUTLOOK_TOKEN_PROVIDER=auto

# Optional Windows overrides:
# OUTLOOK_EDGE_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
# OUTLOOK_EDGE_PROFILE=C:\Users\you\.config\email-mcp\edge-profile
